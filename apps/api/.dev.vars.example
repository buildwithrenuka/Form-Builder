# Copy this file to .dev.vars and fill in your values.
# .dev.vars is loaded automatically by `wrangler dev` and is gitignored.

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Salt mixed into IP addresses before hashing (for rate limiting)
IP_SALT=change-me-to-another-random-string

# Salt used when hashing passwords
PASSWORD_SALT=change-me-to-yet-another-random-string

# Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:4174,http://localhost:5173,http://localhost:5174,http://127.0.0.1:4173,http://127.0.0.1:4174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Public web app URL used in outbound emails
APP_BASE_URL=http://localhost:5173

# ── Razorpay Test Mode (Optional) ───────────────────────────────────────────
# Use your Razorpay test dashboard keys here while integrating payments locally.
# Leave blank to disable paid-form checkout in local development.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret

# ── Email Notifications (Optional) ──────────────────────────────────────────
# Get your key at https://resend.com — free tier: 3,000 emails/month
# For local testing, keep the default sender below unless you have verified your own domain in Resend.
# Resend's onboarding sender is suitable for development and debugging.
# Leave blank to disable (form submissions still work without it)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=FormVerse <onboarding@resend.dev>

# ── Demo credentials (seeded via migrations/0002_seed.sql) ──────────────────
# Email:    demo@formverse.io
# Password: Demo1234!
